# Copy to ".env" — loaded at startup via flutter_dotenv.
# Point this at your CropLens backend (see the backend README).
API_BASE_URL=http://10.0.2.2:5000/api
# Use http://10.0.2.2:5000/api for the Android emulator talking to a backend on your host machine.
# Use http://localhost:5000/api for iOS simulator.
# Use your machine's LAN IP (e.g. http://192.168.1.10:5000/api) for a physical device.
